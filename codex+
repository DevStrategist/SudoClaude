#!/bin/bash
# Codex Root Runner — runs Codex CLI with root privileges.
# Works whether invoked as `codex+` (self-elevates via sudo) or `sudo codex+`.
set -euo pipefail

# 1. Ensure we are root; re-exec through sudo if not.
if [ "$(id -u)" -ne 0 ]; then
    exec sudo "$0" "$@"
fi

# 2. Figure out who invoked us so we can reuse their Codex login/config.
RUN_USER="${SUDO_USER:-root}"
RUN_HOME=""
if command -v getent >/dev/null 2>&1; then
    RUN_HOME="$(getent passwd "$RUN_USER" | cut -d: -f6 || true)"
fi
if [ -z "$RUN_HOME" ] && command -v dscl >/dev/null 2>&1; then
    RUN_HOME="$(dscl . -read "/Users/$RUN_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}' || true)"
fi
[ -n "${RUN_HOME:-}" ] || RUN_HOME="$HOME"

# 3. Locate the codex CLI. root's PATH usually lacks it, so also probe the
#    invoking user's typical install locations.
CODEX_PATH="$(command -v codex 2>/dev/null || true)"
if [ -z "$CODEX_PATH" ]; then
    for p in \
        "$RUN_HOME/.local/bin/codex" \
        "$RUN_HOME/.npm-global/bin/codex" \
        "$RUN_HOME/.cargo/bin/codex" \
        "/usr/local/bin/codex" \
        "/opt/homebrew/bin/codex"; do
        if [ -x "$p" ]; then CODEX_PATH="$p"; break; fi
    done
fi
if [ -z "$CODEX_PATH" ] || [ ! -x "$CODEX_PATH" ]; then
    echo "Error: Codex CLI not found." >&2
    echo "Install Codex for $RUN_USER and verify: codex --version" >&2
    exit 1
fi

# 4. Run Codex as root, in the current directory, reusing the invoking user's
#    HOME so their existing login/config is used (no re-auth needed).
exec env HOME="$RUN_HOME" "$CODEX_PATH" "$@"

#!/bin/bash
# Claude Code Root Runner — runs Claude Code with root privileges.
# Claude Code refuses --dangerously-skip-permissions under root/sudo unless
# IS_SANDBOX=1 is set, so we set it explicitly.
# Works whether invoked as `claude+` (self-elevates via sudo) or `sudo claude+`.
set -euo pipefail

# 1. Ensure we are root; re-exec through sudo if not.
if [ "$(id -u)" -ne 0 ]; then
    exec sudo "$0" "$@"
fi

# 2. Figure out who invoked us so we can reuse their Claude login/config.
RUN_USER="${SUDO_USER:-root}"
RUN_HOME=""
if command -v getent >/dev/null 2>&1; then
    RUN_HOME="$(getent passwd "$RUN_USER" | cut -d: -f6 || true)"
fi
if [ -z "$RUN_HOME" ] && command -v dscl >/dev/null 2>&1; then
    RUN_HOME="$(dscl . -read "/Users/$RUN_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}' || true)"
fi
[ -n "${RUN_HOME:-}" ] || RUN_HOME="$HOME"

# 3. Locate the claude CLI. root's PATH usually lacks it, so also probe the
#    invoking user's typical install locations.
CLAUDE_PATH="$(command -v claude 2>/dev/null || true)"
if [ -z "$CLAUDE_PATH" ]; then
    for p in \
        "$RUN_HOME/.local/bin/claude" \
        "$RUN_HOME/.npm-global/bin/claude" \
        "/usr/local/bin/claude"; do
        if [ -x "$p" ]; then CLAUDE_PATH="$p"; break; fi
    done
fi
if [ -z "$CLAUDE_PATH" ] || [ ! -x "$CLAUDE_PATH" ]; then
    echo "Error: Claude Code CLI not found." >&2
    echo "Install it with: npm install -g @anthropic-ai/claude-code" >&2
    exit 1
fi

# 4. Run Claude as root, in the current directory, reusing the invoking user's
#    HOME so their existing login/config is used (no re-auth needed).
#    IS_SANDBOX=1 lifts Claude Code's root/sudo guard for --dangerously-skip-permissions.
exec env HOME="$RUN_HOME" IS_SANDBOX=1 "$CLAUDE_PATH" --dangerously-skip-permissions "$@"
